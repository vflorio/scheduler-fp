{
  "name": "supervisor",
  "version": "0.1.0",
  "author": {
    "name": "vflorio & ai"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "^1.61.1",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/vite-react": "^7.0.2",
    "@types/node": "^25.0.3",
    "@vitest/ui": "^4.0.16",
    "jsdom": "^27.3.0",
    "syncpack": "^13.0.4",
    "turbo": "^2.10.4",
    "vitest": "^4.0.16"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build-no-cache": "turbo run build --force",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "turbo run format && bunx @biomejs/biome format --write",
    "lint": "turbo run lint && bunx @biomejs/biome check --write",
    "syncpack:check": "syncpack list-mismatches",
    "syncpack:fix": "syncpack fix-mismatches",
    "syncpack:format": "syncpack format",
    "syncpack:list": "syncpack list",
    "test:e2e": "playwright test apps/tests --headed --ui",
    "test:unit": "turbo run test"
  },
  "type": "module",
  "overrides": {
    "@docusaurus/theme-common": "3.10.2",
    "@docusaurus/theme-classic": "3.10.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
