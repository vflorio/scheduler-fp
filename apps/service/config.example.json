{
  "suitest": {
    "tokenId": "your-token-id",
    "tokenPassword": "env:SUISTEST_TOKEN_PASSWORD"
  },
  "slack": {
    "botToken": "env:SLACK_BOT_TOKEN",
    "channelId": "C0123456789"
  },
  "workSchedule": {
    "days": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
    "from": "00:00",
    "to": "23:59"
  },
  "monitoring": {
    "polling": [["constantDelay", "15s"]]
  },
  "log": {
    "level": "info"
  },
  "adb": {
    "port": 5555,
    "connectRetry": [
      ["constantDelay", "400ms"],
      ["exponentialBackoff", "800ms"],
      ["capDelay", "30s"],
      ["limitRetries", 10]
    ]
  }
}
