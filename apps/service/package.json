{
  "name": "@supervisor/service",
  "version": "0.1.0",
  "dependencies": {
    "@supervisor/core": "workspace:*",
    "@supervisor/shell": "workspace:*",
    "fp-ts": "2.16.11",
    "io-ts": "2.2.22",
    "jsonc-parser": "3.3.1",
    "pino": "10.3.1",
    "ts-pattern": "5.9.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "pino-pretty": "13.1.3",
    "typescript": "7.0.2"
  },
  "private": true,
  "scripts": {
    "service:dev": "bun --watch run src/index.ts --config config.example.jsonc",
