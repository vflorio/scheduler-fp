{
  "name": "@supervisor/service",
  "version": "0.1.0",
  "dependencies": {
    "@supervisor/core": "workspace:*",
    "fp-ts": "2.16.11",
    "io-ts": "2.2.22",
    "ts-pattern": "5.9.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.10.1",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "6.0.3"
  },
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "service:build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.cjs",
    "service:start": "node dist/index.cjs --config config.example.json",
    "service:dev": "run-p service-dev:*",
    "service-dev:tsc": "tsc --watch --preserveWatchOutput",
    "service-dev:node": "node --watch dist/index.cjs --config config.example.json",
    "service-dev:esbuild": "pnpm run service:build --watch"
  },
  "type": "module"
}
